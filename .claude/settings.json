{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "output=$(just lint 2>&1); if [ $? -ne 0 ]; then jq -n --arg reason \"$(printf 'Lint check failed. Fix these issues before committing:\\n%s' \"$output\")\" '{\"continue\": false, \"stopReason\": $reason}'; fi",
            "timeout": 120,
            "statusMessage": "Running lint checks..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "MAIN=$(git rev-parse --git-common-dir 2>/dev/null | xargs -I{} dirname {}); [ -f \"$MAIN/.claude/hooks/coordination-check.sh\" ] && bash \"$MAIN/.claude/hooks/coordination-check.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
